# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://user:pass@localhost:5432/ticketbot

# Redis
REDIS_URL=redis://localhost:6379/0

# Telegram Bot Tokens (comma-separated for failover)
TELEGRAM_BOT_TOKENS=token1,token2,token3
TELEGRAM_WEBHOOK_BASE_URL=https://yourdomain.com

# JWT
JWT_SECRET_KEY=your-jwt-secret

# Super Admin (created on first run)
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=changeme123
